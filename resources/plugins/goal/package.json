{
  "name": "goal",
  "version": "0.3.4",
  "displayName": "Goal Manager",
  "description": "Goal mode task management - track progress, manage tasks, and guide LLM execution",
  "xyzAgent": {
    "manifestVersion": 1,
    "main": "index.js",
    "activationEvents": [
      "onStartupFinished"
    ],
    "trustLevel": "trusted",
    "source": "built-in",
    "permissions": [
      "tools.register",
      "hooks.onPiEvent",
      "sessionData.get",
      "sessionData.set"
    ]
  }
}
