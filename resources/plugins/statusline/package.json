{
  "name": "statusline",
  "version": "0.3.13",
  "displayName": "Statusline",
  "description": "Bridges pi extension setStatus events to xyz-agent status bar system",
  "xyzAgent": {
    "manifestVersion": 1,
    "main": "index.js",
    "activationEvents": [
      "onStartupFinished"
    ],
    "trustLevel": "trusted",
    "source": "built-in",
    "permissions": [
      "hooks.onPiEvent"
    ]
  }
}
