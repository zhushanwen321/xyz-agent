        <mxCell id="lg_ws_t" value="WebSocket = 业务/数据（R↔Runtime）" style="text;html=1;align=left;fontSize=10;fontColor=#6c8ebf;" vertex="1" parent="legend">
          <mxGeometry x="40" y="86" width="400" height="16" as="geometry" />
        </mxCell>
        <mxCell id="lg_ipc" value="" style="endArrow=classic;startArrow=classic;startFill=1;html=1;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="legend">
