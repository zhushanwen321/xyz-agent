        <mxCell id="lg_ipc_t" value="IPC = 系统/窗口/进程（R↔Main，Main→Runtime spawn）" style="text;html=1;align=left;fontSize=10;fontColor=#82b366;" vertex="1" parent="legend">
          <mxGeometry x="40" y="108" width="420" height="16" as="geometry" />
        </mxCell>
        <mxCell id="lg_rpc" value="" style="endArrow=classic;startArrow=classic;startFill=1;html=1;strokeColor=#9673a6;strokeWidth=2;" edge="1" parent="legend">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lg_rpc_t" value="stdin/stdout JSON-RPC（Runtime↔pi）" style="text;html=1;align=left;fontSize=10;fontColor=#9673a6;" vertex="1" parent="legend">
          <mxGeometry x="40" y="130" width="360" height="16" as="geometry" />
        </mxCell>
        <mxCell id="lg_type" value="" style="endArrow=open;dashed=1;html=1;strokeColor=#666666;strokeWidth=1;" edge="1" parent="legend">
