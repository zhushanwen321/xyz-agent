        <mxCell id="e_spawn" value="spawn + 端口探测&#xa;(ELECTRON_RUN_AS_NODE=1)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#555555;strokeWidth=2;endArrow=classic;fontSize=11;fontStyle=1;fontColor=#333333;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="main" target="runtime">
