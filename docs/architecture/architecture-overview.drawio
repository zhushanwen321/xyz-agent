        <mxCell id="lg_type_t" value="虚线 = type-only 依赖（无运行时 import）" style="text;html=1;align=left;fontSize=10;fontColor=#666666;" vertex="1" parent="legend">
          <mxGeometry x="40" y="152" width="360" height="16" as="geometry" />
        </mxCell>
        <mxCell id="lg_rules" value="adapters = pi 格式唯一入口 · 每模块只暴露一个 Facade&#xa;session 路由：无 sessionId 的 session-scoped 消息丢弃(D6b)" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#444444;" vertex="1" parent="legend">
          <mxGeometry x="12" y="178" width="446" height="50" as="geometry" />
        </mxCell>

