<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="30.0.4">
  <diagram name="overall-architecture" id="arch1">
    <mxGraphModel dx="2200" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1150" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="xyz-agent 整体架构 · 三进程 · 双通道 · 分层依赖" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="1560" height="34" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="spec: docs/architecture/design.md (D1–D9 + G1–G7) · 基线对比: ../main" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="44" width="1560" height="18" as="geometry" />
        </mxCell>

        <!-- shared banner (type-only bridge) -->
        <mxCell id="shared" value="@xyz-agent/shared   ·   协议 union (ClientMessageMap/ServerMessageMap) · 领域类型 · ENV 白名单   ·   type-only，运行时零 import 穿透" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontStyle=1;fontSize=12;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="74" width="1560" height="46" as="geometry" />
        </mxCell>

        <!-- ============ RENDERER swimlane ============ -->
        <mxCell id="renderer" value="①  RENDERER 进程  (Vue 3 + Pinia + TS + xyz-ui)" style="swimlane;startSize=34;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=13;swimlaneFillColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="470" height="560" as="geometry" />
        </mxCell>
        <mxCell id="r1" value="R1 · UI 展示层&#xa;components/{域}/  ·  design-system/&#xa;展示组件 props/emit · 容器组件注入 store" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="renderer">
          <mxGeometry x="20" y="44" width="430" height="64" as="geometry" />
        </mxCell>
        <mxCell id="r2" value="R2 · 业务逻辑 Composables&#xa;features/  唯一同时碰 api + store（useChat/useSession/useModel…）&#xa;effects/   传输胶水·不碰 store（useConnection/useChatScroll）&#xa;logic/    纯函数（应归 lib/）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="renderer">
          <mxGeometry x="20" y="118" width="430" height="96" as="geometry" />
        </mxCell>
        <mxCell id="r3" value="R3 · 状态 Stores (Pinia)&#xa;按 sessionId 分区 · store 间不互 import · chat/session/tree 各管唯一切片" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="renderer">
          <mxGeometry x="20" y="224" width="430" height="58" as="geometry" />
        </mxCell>
        <mxCell id="r4" value="R4 · API Client   ⭐ NEW · 渲染进程唯一出口&#xa;command(Promise)+event(订阅) 混合门面&#xa;抹平 WS/IPC 通道选择 · session 路由第 2 层(D6b)&#xa;mock 注入点(D8) · 对组件屏蔽底层" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;strokeWidth=2;" vertex="1" parent="renderer">
          <mxGeometry x="20" y="292" width="430" height="96" as="geometry" />
        </mxCell>
        <mxCell id="r5" value="R5 · 传输层（纯管道·无业务语义）&#xa;ws-client (WS 字节·重连退避) · event-bus (按 msg.type 分发)&#xa;electronAPI (preload 注入的 IPC 代理)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="renderer">
          <mxGeometry x="20" y="398" width="430" height="76" as="geometry" />
        </mxCell>
        <mxCell id="r_note" value="依赖铁律：features 唯一同时 import api/ 和 stores/&#xa;effects 只 import api/（不碰 store）&#xa;传输层无业务语义（&quot;session.created 后刷新列表&quot; 属 features）" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#555555;" vertex="1" parent="renderer">
          <mxGeometry x="20" y="484" width="430" height="64" as="geometry" />
        </mxCell>

        <!-- ============ MAIN swimlane ============ -->
        <mxCell id="main" value="②  MAIN 进程  (Electron Main · 特权层)" style="swimlane;startSize=34;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;swimlaneFillColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="600" y="150" width="420" height="360" as="geometry" />
        </mxCell>
        <mxCell id="m1" value="M1 · Process Supervisor&#xa;runtime 子进程 spawn/kill/端口探测/健康检查&#xa;ELECTRON_RUN_AS_NODE=1 + process.execPath" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;" vertex="1" parent="main">
          <mxGeometry x="20" y="44" width="380" height="76" as="geometry" />
        </mxCell>
        <mxCell id="m2" value="M2 · Window Manager&#xa;原生窗口 + 跨窗口注册表（读副本）&#xa;← D2 双真相源：单写者 + 读副本" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;" vertex="1" parent="main">
          <mxGeometry x="20" y="130" width="380" height="76" as="geometry" />
        </mxCell>
        <mxCell id="m3" value="M3 · OS Gateway&#xa;对话框 / 外链 / 全局快捷键 / 全屏&#xa;触碰 OS 特权 → 必须 Main 进程" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;" vertex="1" parent="main">
          <mxGeometry x="20" y="216" width="380" height="76" as="geometry" />
        </mxCell>
        <mxCell id="m_note" value="Main 非「thin shell」：持窗口注册表(领域状态 D2)&#xa;+ 编排 Runtime 生命周期(D1)。三者职责互不交叉" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#555555;" vertex="1" parent="main">
          <mxGeometry x="20" y="300" width="380" height="48" as="geometry" />
        </mxCell>

        <!-- ============ RUNTIME swimlane ============ -->
        <mxCell id="runtime" value="③  RUNTIME 子进程  (Node.js · 组合根 index.ts 线性 3-Phase DI)" style="swimlane;startSize=34;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=13;swimlaneFillColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="600" y="560" width="1000" height="410" as="geometry" />
        </mxCell>
        <mxCell id="t1" value="T1 · Transport（纯路由 + 广播）&#xa;transport/server.ts + handlers/  ·  type→handler 声明式映射&#xa;不持 service 具体类，只持 handler；不含业务决策" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="runtime">
          <mxGeometry x="20" y="44" width="960" height="76" as="geometry" />
        </mxCell>
        <mxCell id="t2" value="T2 · Services（业务核心 · 经 interface）&#xa;session/ 拆 3 模块(Facade ISessionService: lifecycle+dispatcher+scanner) · config/ · model/ · tree/ · extension/&#xa;plugin-service/  ← D5 完整纵向切片（四层全占·Facade = IPluginService · 只经它越界）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="runtime">
          <mxGeometry x="20" y="130" width="960" height="86" as="geometry" />
        </mxCell>
        <mxCell id="t3" value="T3 · Adapters（防腐层 · pi 格式唯一入口）&#xa;event-adapter (pi 事件 → ServerMessage) · message-converter (pi 历史 → Message[])&#xa;业务代码出现 if(event.type==='pi_xxx') = 防腐层漏了" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="runtime">
          <mxGeometry x="20" y="226" width="960" height="76" as="geometry" />
        </mxCell>
        <mxCell id="t4" value="T4 · Infra（外部系统连接器 · 不知业务概念）&#xa;rpc-client（pi JSON-RPC，唯一碰 pi stdin/stdout）· process-manager（唯一 spawn pi 子进程）· npm-installer · scanners" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="runtime">
          <mxGeometry x="20" y="312" width="960" height="70" as="geometry" />
        </mxCell>
        <mxCell id="rt_dep" value="单向依赖无环：transport → services → adapters → infra" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontColor=#7a5c00;fontStyle=2;" vertex="1" parent="runtime">
          <mxGeometry x="20" y="388" width="960" height="18" as="geometry" />
        </mxCell>

        <!-- ============ pi subprocess ============ -->
        <mxCell id="pi" value="pi 子进程&#xa;(SubAgent extension · fork 版 xyz-pi)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1010" y="1010" width="360" height="60" as="geometry" />
        </mxCell>

        <!-- ============ Legend ============ -->
        <mxCell id="legend" value="关键约束 / Legend" style="swimlane;startSize=26;fillColor=#fafafa;strokeColor=#999999;fontStyle=1;fontSize=11;swimlaneFillColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="40" y="730" width="470" height="240" as="geometry" />
        </mxCell>
        <mxCell id="lg1" value="⭐ R4 API Client：渲染进程唯一出口，对组件屏蔽 WS/IPC&#xa;依赖方向 = 单向（编译期·type-only 经 shared）&#xa;通信方向 = 双向（运行期·请求/响应 + 事件流）" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#444444;" vertex="1" parent="legend">
          <mxGeometry x="12" y="34" width="446" height="50" as="geometry" />
