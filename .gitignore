!.env.example
.DS_Store
.env
.env.*
.superpowers/2026-04-*
.superpowers/brainstorm/
.xyz-harness/gate/
*.local
*.log
dist/
node_modules/
sidecar/dist/
sidecar/node_modules/
src-tauri/binaries/
src-tauri/gen/
src-tauri/target/
src/dist/
src/node_modules/
superpowers/20*/
target/
.xyz-harness/workflow-state.json
.claude/worktrees/

# pi binary and resources (downloaded by prepare-pi-resources.sh in CI)
src-electron/resources/pi/pi-*
src-electron/resources/pi/assets
src-electron/resources/pi/export-html
src-electron/resources/pi/package.json
src-electron/resources/pi/photon_rs_bg.wasm
src-electron/resources/pi/theme
# pi agent data (runtime data only — bundled extensions & skills are tracked)
src-electron/resources/pi/agent/*
!src-electron/resources/pi/agent/extensions/
!src-electron/resources/pi/agent/skills/
.pi/
.pi/infinite-context/

# Electron binary cache (immutable, shared across worktrees)
.electron-dist/
**/__pycache__/
*.pyc
