!.env.example
.DS_Store
.env
.env.*
.superpowers/2026-04-*
.superpowers/brainstorm/
.xyz-harness/gate/
*.local
*.log
dist/
node_modules/
sidecar/dist/
sidecar/node_modules/
src-tauri/binaries/
src-tauri/gen/
src-tauri/target/
src/dist/
src/node_modules/
superpowers/20*/
target/
.xyz-harness/workflow-state.json
.claude/worktrees/

# pi resources — all generated by prepare-pi-resources.sh (pi binary from gh release
# + extensions/skills copied from vendor/ submodules). Nothing under here is tracked.
src-electron/resources/
.pi/
.pi/infinite-context/

# Electron binary cache (immutable, shared across worktrees)
.electron-dist/
**/__pycache__/
*.pyc

# Playwright E2E artifacts (test results / reports / cache)
/test-results/
/playwright-report/
/playwright/.cache/
/blob-report/
/playwright/.auth/
