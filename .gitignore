# pi resources — pi binary downloaded by prepare-pi-resources.sh from badlogic/pi-mono
# gh releases. Nothing under here is tracked. Builtin extensions are npm deps (root
# package.json), skills are user/project-level — neither is bundled here.
apps/electron/resources/
.pi/
.pi/infinite-context/

# Electron binary cache (immutable, shared across worktrees)
.electron-dist/
**/__pycache__/
*.pyc

# Playwright E2E artifacts (test results / reports / cache)
/test-results/
/playwright-report/
/playwright/.cache/
/blob-report/
/playwright/.auth/

# ZCode plan mode artifacts (session-local planning docs)
.zcode/plans/

# Legacy build dir from pre-monorepo layout (commit 0f6eed87 migrated src-electron/
# to packages/* + apps/electron). Leftover build artifacts + node_modules linger in
# some worktrees; ignore to prevent accidental staging.
src-electron/

# Ad-hoc screenshots (debugging artifacts, not source)
screenshot.png
