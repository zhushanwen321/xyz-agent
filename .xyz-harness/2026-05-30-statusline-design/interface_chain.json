{
  "version": 1,
  "methods": [
    {
      "name": "translate",
      "class": "EventAdapter",
      "module": "event-adapter",
      "params": [
        { "name": "event", "type": "Record<string, unknown>" }
      ],
      "returns": "ServerMessage | null",
      "edge_cases": [
        "method === 'setStatus' → return plugin:statusSetUpdate message",
        "method === 'setWidget' → return null (unchanged)",
        "unknown method → existing behavior"
      ],
      "spec_ref": "AC-1"
    },
    {
      "name": "handleBridgeRequest",
      "class": "Server",
      "module": "server",
      "params": [
        { "name": "sessionId", "type": "string" },
        { "name": "requestId", "type": "string" },
        { "name": "method", "type": "string" },
        { "name": "data", "type": "Record<string, unknown>" }
      ],
      "returns": "Promise<void>",
      "edge_cases": [
        "bridge:event → call pluginService.handleBridgeEvent(eventName, data, sessionId)",
        "bridge:tool_execute → existing behavior",
        "bridge:intercept → existing behavior"
      ],
      "spec_ref": "AC-8"
    },
    {
      "name": "handleBridgeEvent",
      "class": "PluginService",
      "module": "plugin-service",
      "params": [
        { "name": "eventName", "type": "string" },
        { "name": "data", "type": "unknown" },
        { "name": "sessionId", "type": "string" }
      ],
      "returns": "void",
      "edge_cases": [
        "eventName not matched by any hook → no-op",
        "multiple hooks match → all executed in registration order"
      ],
      "spec_ref": "AC-8"
    },
    {
      "name": "updateStatusBarItem",
      "class": "PluginService",
      "module": "plugin-service",
      "params": [
        { "name": "pluginId", "type": "string" },
        { "name": "id", "type": "string" },
        { "name": "text", "type": "string" },
        { "name": "options", "type": "StatusBarItemOptions | undefined" }
      ],
      "returns": "void",
      "edge_cases": [
        "options omitted → defaults (priority=100, scope='global')",
        "id already exists → update in place",
        "text is empty or undefined → remove item from map",
        "Map change → broadcast full items list via WS"
      ],
      "spec_ref": "AC-6"
    },
    {
      "name": "activate",
      "class": "StatuslinePlugin",
      "module": "statusline-plugin",
      "params": [
        { "name": "api", "type": "Phase2AgentAPI" }
      ],
      "returns": "{ dispose(): void }",
      "edge_cases": [
        "Unknown setStatus key → default metadata (priority=100, scope=global)",
        "text is undefined/empty → call updateStatusBarItem with empty text (removes item)"
      ],
      "spec_ref": "AC-1"
    },
    {
      "name": "getSessionStatusBarItems",
      "class": "usePluginStore",
      "module": "plugin-store",
      "params": [
        { "name": "sessionId", "type": "string" }
      ],
      "returns": "PluginStatusItem[]",
      "edge_cases": [
        "no items with matching sessionId → empty array",
        "items with scope='global' excluded",
        "items sorted by priority"
      ],
      "spec_ref": "AC-3"
    },
    {
      "name": "setStatusBarItems",
      "class": "usePluginStore",
      "module": "plugin-store",
      "params": [
        { "name": "items", "type": "PluginStatusItem[]" }
      ],
      "returns": "void",
      "edge_cases": [
        "merge with existing items by (pluginId, id) key",
        "items with empty text → remove from store"
      ],
      "spec_ref": "AC-6"
    }
  ],
  "data_flows": [
    {
      "id": "flow-setstatus-to-frontend",
      "description": "pi extension setStatus → frontend rendering",
      "chain": [
        {
          "method": "EventAdapter.translate",
          "input": "pi RPC extension_ui_request { method: 'setStatus', key, text }",
          "output": "ServerMessage { type: 'plugin:statusSetUpdate', payload: { sessionId, key, text } }"
        },
        {
          "method": "Server.handleBridgeRequest",
          "input": "bridge event with method 'extension_ui_request'",
          "output": "calls PluginService.handleBridgeEvent('statusSetUpdate', payload, sessionId)"
        },
        {
          "method": "PluginService.handleBridgeEvent",
          "input": "eventName='statusSetUpdate', data={sessionId, key, text}",
          "output": "executes registered plugin hooks → statusline plugin handler"
        },
        {
          "method": "StatuslinePlugin.activate → hook handler",
          "input": "event data { sessionId, key, text }",
          "output": "calls api.ui.updateStatusBarItem(id, text, { priority, tooltip, scope, sessionId })"
        },
        {
          "method": "PluginService.updateStatusBarItem",
          "input": "pluginId, id, text, options",
          "output": "updates Map, broadcasts plugin:statusBarUpdate via WS"
        },
        {
          "method": "usePluginStore.setStatusBarItems",
          "input": "WS message plugin:statusBarUpdate { items: StatusBarItem[] }",
          "output": "updates reactive statusBarItems ref"
        }
      ]
    },
    {
      "id": "flow-global-statusbar",
      "description": "Global statusbar rendering from store",
      "chain": [
        {
          "method": "usePluginStore.globalStatusBarItems",
          "input": "statusBarItems ref",
          "output": "computed: filtered scope='global', sorted by priority"
        },
        {
          "method": "AppStatusbar.vue template",
          "input": "globalStatusBarItems computed",
          "output": "renders extension chips in right section"
        }
      ]
    },
    {
      "id": "flow-session-strip",
      "description": "Session strip rendering from store",
      "chain": [
        {
          "method": "usePluginStore.getSessionStatusBarItems",
          "input": "sessionId prop + statusBarItems ref",
          "output": "filtered scope='per-session' && sessionId matches, sorted by priority"
        },
        {
          "method": "SessionStrip.vue template",
          "input": "getSessionStatusBarItems(sessionId)",
          "output": "renders extension chips below input"
        }
      ]
    }
  ]
}
