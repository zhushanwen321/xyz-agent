{
  "version": "1.0",
  "description": "Plugin system interface chain — L2 plan",
  "methods": [
    {
      "name": "handleBridgeToolExecute",
      "class": "PluginService",
      "module": "backend",
      "params": [
        { "name": "request", "type": "BridgeToolExecuteRequest" }
      ],
      "returns": "Promise<BridgeToolExecuteResponse>",
      "edgeCases": [
        "Tool not found → isError: true",
        "Worker crashed → isError: true",
        "RPC timeout 30s → isError: true"
      ]
    },
    {
      "name": "executeHooks",
      "class": "PluginService",
      "module": "backend",
      "params": [
        { "name": "hookType", "type": "string" },
        { "name": "context", "type": "HookContext" }
      ],
      "returns": "Promise<HookResult>",
      "edgeCases": [
        "No handlers → { blocked: false }",
        "Single handler timeout 5s → skip (not block)",
        "blocked: true → stop chain"
      ]
    },
    {
      "name": "fetchPlugins",
      "class": "usePluginStore",
      "module": "frontend",
      "params": [],
      "returns": "Promise<void>",
      "edgeCases": [
        "WS error → keep last state"
      ]
    },
    {
      "name": "togglePlugin",
      "class": "usePluginStore",
      "module": "frontend",
      "params": [
        { "name": "id", "type": "string" },
        { "name": "enabled", "type": "boolean" }
      ],
      "returns": "Promise<void>",
      "edgeCases": [
        "built-in → no-op",
        "activation fails → revert UI state"
      ]
    },
    {
      "name": "approvePermissions",
      "class": "usePluginStore",
      "module": "frontend",
      "params": [
        { "name": "id", "type": "string" },
        { "name": "perms", "type": "string[]" }
      ],
      "returns": "Promise<void>",
      "edgeCases": []
    },
    {
      "name": "revokePermissions",
      "class": "usePluginStore",
      "module": "frontend",
      "params": [
        { "name": "id", "type": "string" }
      ],
      "returns": "Promise<void>",
      "edgeCases": []
    },
    {
      "name": "getConfig",
      "class": "usePluginStore",
      "module": "frontend",
      "params": [
        { "name": "pluginId", "type": "string" }
      ],
      "returns": "Promise<Record<string, unknown>>",
      "edgeCases": [
        "No config → empty object"
      ]
    },
    {
      "name": "setConfig",
      "class": "usePluginStore",
      "module": "frontend",
      "params": [
        { "name": "pluginId", "type": "string" },
        { "name": "key", "type": "string" },
        { "name": "value", "type": "unknown" }
      ],
      "returns": "Promise<void>",
      "edgeCases": []
    },
    {
      "name": "watchAndReload",
      "class": "PluginActivator",
      "module": "backend",
      "params": [
        { "name": "pluginPath", "type": "string" }
      ],
      "returns": "void",
      "edgeCases": [
        "built-in path → ignored",
        "deactivate timeout 5s → force terminate"
      ]
    },
    {
      "name": "getCachedSessionData",
      "class": "PluginService",
      "module": "backend",
      "params": [
        { "name": "sessionId", "type": "string" },
        { "name": "key", "type": "string" }
      ],
      "returns": "unknown | undefined",
      "edgeCases": [
        "Cache miss → undefined (caller falls back to bridge)"
      ]
    },
    {
      "name": "setCachedSessionData",
      "class": "PluginService",
      "module": "backend",
      "params": [
        { "name": "sessionId", "type": "string" },
        { "name": "key", "type": "string" },
        { "name": "value", "type": "unknown" }
      ],
      "returns": "void",
      "edgeCases": [
        "Cache capacity 10MB per plugin → evict oldest"
      ]
    }
  ],
  "data_flows": [
    {
      "id": "df-tool-execute",
      "name": "Tool Execution Flow",
      "specRef": "AC-A1",
      "chain": [
        { "method": "BridgeExtension.handleToolExecute", "direction": "pi → bridge" },
        { "method": "server.ts handleBridgeToolExecute", "direction": "bridge → sidecar" },
        { "method": "PluginService.handleBridgeToolExecute", "direction": "sidecar internal" },
        { "method": "PluginRPCServer.invoke plugin.tool.execute", "direction": "main → worker" },
        { "method": "Worker.toolHandler", "direction": "worker internal" },
        { "method": "PluginRPCServer response", "direction": "worker → main" },
        { "method": "BridgeExtension response", "direction": "bridge → pi" }
      ]
    },
    {
      "id": "df-hook-chain",
      "name": "Hook Serialization Flow",
      "specRef": "AC-A2",
      "chain": [
        { "method": "server.ts beforeSendMessage", "direction": "trigger" },
        { "method": "PluginService.executeHooks", "direction": "sidecar internal" },
        { "method": "PluginService._collectHandlers", "direction": "internal sort" },
        { "method": "PluginRPCServer.invoke plugin.hooks.invoke (handler A)", "direction": "main → worker A" },
        { "method": "Worker.hookHandler A", "direction": "worker A internal" },
        { "method": "PluginRPCServer response A", "direction": "worker A → main" },
        { "method": "PluginService._checkBlock", "direction": "internal check" },
        { "method": "PluginRPCServer.invoke plugin.hooks.invoke (handler B)", "direction": "main → worker B" },
        { "method": "Worker.hookHandler B", "direction": "worker B internal" },
        { "method": "return HookResult", "direction": "to caller" }
      ]
    },
    {
      "id": "df-plugin-list",
      "name": "Plugin List Flow",
      "specRef": "AC-B1",
      "chain": [
        { "method": "PluginStore.fetchPlugins", "direction": "frontend init" },
        { "method": "wsClient.send plugin.list", "direction": "renderer → sidecar WS" },
        { "method": "server.ts handleMessage", "direction": "WS dispatch" },
        { "method": "PluginService.listPlugins", "direction": "sidecar internal" },
        { "method": "wsClient receive config.plugins", "direction": "sidecar → renderer WS" },
        { "method": "PluginStore._updatePlugins", "direction": "store update" }
      ]
    },
    {
      "id": "df-permission-approval",
      "name": "Permission Approval Flow",
      "specRef": "AC-B7",
      "chain": [
        { "method": "PluginActivator.activatePlugin", "direction": "check permissions" },
        { "method": "server.ts broadcast plugin:permissionRequest", "direction": "sidecar → renderer WS" },
        { "method": "PluginPermissionDialog.show", "direction": "UI display" },
        { "method": "PluginStore.approvePermissions", "direction": "user action" },
        { "method": "wsClient.send plugin.approvePermissions", "direction": "renderer → sidecar WS" },
        { "method": "PluginService.grantPermissions", "direction": "sidecar internal" },
        { "method": "PluginPermissionStorage.save", "direction": "persist" }
      ]
    },
    {
      "id": "df-hot-reload",
      "name": "Hot Reload Flow",
      "specRef": "AC-C5",
      "chain": [
        { "method": "fs.watch change event", "direction": "OS → node" },
        { "method": "PluginActivator._debouncedReload", "direction": "300ms debounce" },
        { "method": "PluginService.deactivatePlugin", "direction": "main → worker (terminate)" },
        { "method": "PluginService.activatePlugin", "direction": "main → new worker" },
        { "method": "server.ts broadcast plugin:statusChange", "direction": "sidecar → renderer WS" }
      ]
    },
    {
      "id": "df-session-data-cache",
      "name": "SessionData Cache Flow",
      "specRef": "AC-C4",
      "chain": [
        { "method": "Worker.plugin.sessionData.set", "direction": "worker → main RPC" },
        { "method": "PluginService.setCachedSessionData", "direction": "write cache + mark dirty" },
        { "method": "PluginService._asyncFlushToBridge", "direction": "cache → bridge (5s interval)" },
        { "method": "Worker.plugin.sessionData.get", "direction": "worker → main RPC" },
        { "method": "PluginService.getCachedSessionData", "direction": "cache hit → return" },
        { "method": "Bridge.plugin.appendEntry (fallback)", "direction": "cache miss → bridge" }
      ]
    }
  ]
}
