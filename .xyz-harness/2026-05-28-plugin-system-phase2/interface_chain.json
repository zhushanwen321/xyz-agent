{
  "version": "1.0",
  "description": "Plugin System Phase 2 interface chain — method signatures, data flows, and AC coverage",
  "methods": [
    { "name": "check", "class": "PermissionChecker", "params": "pluginId: string, method: string", "returns": "boolean" },
    { "name": "grant", "class": "PermissionChecker", "params": "pluginId: string, permissions: string[]", "returns": "void" },
    { "name": "revoke", "class": "PermissionChecker", "params": "pluginId: string", "returns": "void" },
    { "name": "load", "class": "PermissionChecker", "params": "", "returns": "Promise<void>" },
    { "name": "save", "class": "PermissionChecker", "params": "", "returns": "Promise<void>" },
    { "name": "tool_register", "class": "PluginRPCServer", "params": "pluginId: string, tool: ToolRegistration", "returns": "string" },
    { "name": "slashCommand_register", "class": "PluginRPCServer", "params": "pluginId: string, cmd: CommandRegistration", "returns": "string" },
    { "name": "hook_register", "class": "PluginRPCServer", "params": "pluginId: string, hookType: HookType, handlerId: string", "returns": "void" },
    { "name": "sessionData_get", "class": "PluginRPCServer", "params": "sessionId: string, key: string", "returns": "Promise<unknown>" },
    { "name": "sessionData_set", "class": "PluginRPCServer", "params": "sessionId: string, key: string, value: unknown", "returns": "Promise<void>" },
    { "name": "sessionData_delete", "class": "PluginRPCServer", "params": "sessionId: string, key: string", "returns": "Promise<void>" },
    { "name": "sessionData_keys", "class": "PluginRPCServer", "params": "sessionId: string", "returns": "Promise<string[]>" },
    { "name": "session_sendMessage", "class": "PluginRPCServer", "params": "params: {sessionId?: string, role: string, content: string}", "returns": "Promise<MessageResult>" },
    { "name": "config_get", "class": "PluginRPCServer", "params": "pluginId: string, key: string", "returns": "unknown" },
    { "name": "config_set", "class": "PluginRPCServer", "params": "pluginId: string, key: string, value: unknown", "returns": "void" },
    { "name": "ui_showInput", "class": "PluginRPCServer", "params": "pluginId: string, options: InputOptions", "returns": "Promise<string | null>" },
    { "name": "ui_showSelect", "class": "PluginRPCServer", "params": "pluginId: string, options: SelectOptions", "returns": "Promise<string | null>" },
    { "name": "ui_showConfirm", "class": "PluginRPCServer", "params": "pluginId: string, options: ConfirmOptions", "returns": "Promise<boolean>" },
    { "name": "ui_notify", "class": "PluginRPCServer", "params": "pluginId: string, message: string, level: string", "returns": "void" },
    { "name": "ui_updateStatusBarItem", "class": "PluginRPCServer", "params": "pluginId: string, item: StatusBarItem", "returns": "void" },
    { "name": "agent_setModel", "class": "PluginRPCServer", "params": "pluginId: string, modelId: string", "returns": "void" },
    { "name": "agent_setThinking", "class": "PluginRPCServer", "params": "pluginId: string, level: string", "returns": "void" },
    { "name": "workspace_findFiles", "class": "PluginRPCServer", "params": "pattern: string", "returns": "Promise<string[]>" },
    { "name": "bridge_sync", "class": "BridgeExtension", "params": "method: 'bridge:sync'", "returns": "{tools: ToolSchema[], commands: CommandSchema[]}" },
    { "name": "bridge_tool_execute", "class": "BridgeExtension", "params": "{toolName, toolCallId, params, sessionId}", "returns": "{content, details?, isError?}" },
    { "name": "bridge_event", "class": "BridgeExtension", "params": "{eventName, data, sessionId}", "returns": "void" },
    { "name": "bridge_intercept", "class": "BridgeExtension", "params": "{eventName, data, sessionId}", "returns": "{injectedMessages?}" },
    { "name": "bridge_append_entry", "class": "BridgeExtension", "params": "{type, data, sessionId}", "returns": "{success: boolean}" },
    { "name": "executeHooks", "class": "PluginService", "params": "hookType: string, context: HookContext", "returns": "Promise<HookResult>" },
    { "name": "syncToolsToBridge", "class": "PluginService", "params": "", "returns": "Promise<void>" },
    { "name": "handleBridgeToolExecute", "class": "PluginService", "params": "request: BridgeToolRequest", "returns": "Promise<BridgeToolResult>" },
    { "name": "togglePlugin", "class": "PluginService", "params": "id: string, enabled: boolean", "returns": "Promise<void>" },
    { "name": "activateWithDeps", "class": "PluginActivator", "params": "plugins: PluginDescriptor[]", "returns": "Promise<void>" },
    { "name": "topologicalSort", "class": "PluginActivator", "params": "plugins: PluginDescriptor[]", "returns": "PluginDescriptor[]" }
  ],
  "data_flows": [
    {
      "id": "flow-tool-execute",
      "chain": ["pi LLM calls proxy tool", "BridgeExtension → extension_ui_request(bridge:tool_execute)", "SidecarServer → PluginService.handleBridgeToolExecute", "PluginRPC → Worker execute", "Result: Worker → PluginRPC → PluginService → SidecarServer → extension_ui_response → Bridge → pi"]
    },
    {
      "id": "flow-event-forward",
      "chain": ["pi emits event", "BridgeExtension → extension_ui_request(bridge:event)", "SidecarServer → PluginService.executeHooks", "Each Worker hook handler called via PluginRPC"]
    },
    {
      "id": "flow-intercept",
      "chain": ["pi emits before_agent_start", "BridgeExtension → extension_ui_request(bridge:intercept)", "SidecarServer → PluginService.executeHooks", "Goal plugin returns injectedMessages", "Bridge injects into pi context"]
    },
    {
      "id": "flow-session-data",
      "chain": ["Plugin calls api.sessionData.set(key, value)", "Worker → PluginRPC → sessionData_set handler", "Handler updates mirror + sends bridge:append_entry", "Bridge → pi.appendEntry(customType, data)"]
    },
    {
      "id": "flow-sendmessage-hook",
      "chain": ["User sends message → SessionService.sendMessage", "PluginService.executeHooks(message:beforeSend)", "Handler returns {blocked/transformedContent}", "Final content sent to pi via RpcClient"]
    }
  ]
}
