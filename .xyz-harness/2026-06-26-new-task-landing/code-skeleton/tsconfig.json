{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "paths": {
      "@/*": ["./src-electron/renderer/src/*"],
      "@xyz-agent/shared": ["./src-electron/shared/src"]
    }
  },
  "include": [
    "src-electron/**/*.ts",
    "src-electron/**/*.vue",
    "src-electron/**/*.d.ts"
  ]
}
