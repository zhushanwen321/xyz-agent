{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "paths": {
      "@shared/*": ["shared/*"]
    },
    "baseUrl": "."
  },
  "include": [
    "shared/**/*.ts",
    "runtime/**/*.ts"
  ]
}
