# pnpm 配置
# ──────────────────────────────────────────────────────────────
# node-linker=hoisted：使用扁平 node_modules 结构（与 npm 相同）。
# 原因：Electron + electron-builder 对 node_modules 结构有硬编码假设
# （electron/install.js 定位 dist、electron-builder 收集 files、path.txt 写入）。
# pnpm 默认的 symlink layout 会让这些工具找不到文件。
# 代价：失去 pnpm 的 phantom deps 防护，但保留单 lock + workspace 协议 + store 节省磁盘的优势。
# 详见 ADR-0032「决策修订」段落。
node-linker=hoisted

# 忽略 pnpm 对 peer deps 的严格检查（Electron 生态 peer dep 声明普遍不规范）
strict-peer-dependencies=false

# .pnpm-store 位置（workspace 级共享，多 worktree 复用）
# 默认在 ~/.local/share/pnpm/store，不改
