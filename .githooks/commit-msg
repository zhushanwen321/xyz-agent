#!/bin/bash
# commit-msg: Conventional Commits 格式检查
MSG=$(cat "$1")
FIRST_LINE=$(echo "$MSG" | head -1)

if ! echo "$FIRST_LINE" | grep -qE "^(feat|fix|refactor|test|docs|chore|ci|perf|style|build)(\(.+\))?: .{1,80}"; then
  echo "ERROR: commit message 不符合 Conventional Commits 格式"
  echo ""
  echo "格式: <type>(<scope>): <description>"
  echo "类型: feat, fix, refactor, test, docs, chore, ci, perf, style, build"
  echo "示例: feat(commands): add send_message handler"
  echo ""
  echo "当前消息: $FIRST_LINE"
  exit 1
fi
