#!/bin/bash
# pre-commit: 确保代码质量
set -e

# 确保 PATH 包含常用工具路径
export PATH="$HOME/.cargo/bin:$HOME/.local/bin:/usr/local/bin:$PATH"

ROOT_DIR="$(git rev-parse --show-toplevel)"

HOOKS_DIR="$(dirname "$0")"

echo "[pre-commit] dependency direction check..."
cd "$ROOT_DIR" && bash "$HOOKS_DIR/check_deps.sh"

echo "[pre-commit] file size check..."
cd "$ROOT_DIR" && bash "$HOOKS_DIR/check_file_size.sh"

echo "[pre-commit] eslint check..."
STAGED_FRONTEND=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(vue|ts|js)$' | grep -v node_modules | grep -v src-tauri || true)
if [ -n "$STAGED_FRONTEND" ]; then
  cd "$ROOT_DIR" && npx eslint $STAGED_FRONTEND --max-warnings=0 2>&1 | tail -5
  if [ $? -ne 0 ]; then
    echo "[pre-commit] ESLint check failed. --max-warnings=0 is enforced: all warnings (including pre-existing ones) must be fixed before committing."
    echo "Skip with: SKIP_ESLINT=1 git commit -m '...'"
    exit 1
  fi
fi

echo "[pre-commit] cargo test..."
cd "$ROOT_DIR/src-tauri" && cargo test --quiet 2>&1 | tail -3

echo "[pre-commit] npm build..."
cd "$ROOT_DIR" && npm run build 2>&1 | tail -1

echo "[pre-commit] all checks passed"
