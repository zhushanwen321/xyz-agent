{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist/main",
    "rootDir": "main",
    "strict": true,
    "resolveJsonModule": true,
    "declaration": false
  },
  "include": ["main/**/*.ts"]
}
