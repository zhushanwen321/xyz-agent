{
  "name": "hello-world",
  "version": "0.3.7",
  "description": "A test plugin for xyz-agent",
  "displayName": "Hello World",
  "xyzAgent": {
    "manifestVersion": 1,
    "main": "index.js",
    "activationEvents": [
      "onStartupFinished",
      "onSlashCommand:hello"
    ],
    "trustLevel": "trusted",
    "contributes": {
      "slashCommands": [
        {
          "name": "hello",
          "description": "Say hello"
        }
      ]
    }
  }
}
