{
  "name": "xyz-agent",
  "version": "0.8.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @xyz-agent/electron dev",
    "build": "pnpm --filter @xyz-agent/electron build",
    "lint": "eslint .",
    "prepare": "bash .githooks/install-hooks.sh",
    "build:e2e": "pnpm --filter @xyz-agent/electron build:e2e",
    "test:e2e": "playwright test",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release:npm": "pnpm --filter @xyz-agent/extension-protocol build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.1",
    "typescript": "^5.8",
    "typescript-eslint": "^8.59.2"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.1",
      "tsup>esbuild": "^0.28.1"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "electron",
      "vue-demi"
    ]
  }
}
