{
  "name": "xyz-agent",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "src-electron/renderer",
    "src-electron/runtime",
    "src-electron/shared",
    "packages/plugin-sdk"
  ],
  "scripts": {
    "dev": "cd src-electron && npm run dev",
    "build": "cd src-electron && npm run build",
    "lint": "eslint .",
    "prepare": "bash .githooks/install-hooks.sh",
    "build:e2e": "cd src-electron && npm run build:main && npm run build:preload && npm run build:vite",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@zhushanwen/pi-goal": "^0.4.0",
    "@zhushanwen/pi-structured-output": "^0.3.2",
    "@zhushanwen/pi-subagents": "^0.1.1",
    "@zhushanwen/pi-todo": "^0.3.0",
    "@zhushanwen/pi-workflow": "^1.1.3",
    "tar": "^7.5.16"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.1",
    "typescript": "^5.8",
    "typescript-eslint": "^8.59.2"
  }
}
